aws_region                 = "us-east-1"
project_name               = "example-app"
environment                = "dev"
instance_type              = "t3.micro"
backend_root_volume_gb     = 10
db_instance_class          = "db.t4g.micro"
db_storage_gb              = 20
db_max_storage_gb          = 100
db_name                    = "app_db"
db_admin_username          = "db_admin"
db_admin_password          = "change-me-admin"
db_migration_username      = "db_migration"
db_migration_password      = "change-me-migration"
db_app_username            = "app_user"
db_app_password            = "change-me-app"
first_admin_email          = "admin@example.com"
first_admin_password       = "change-me-first-admin"
first_admin_firstname      = "Admin"
first_admin_lastname       = "User"
first_admin_nickname       = "admin"
frontend_bucket_name       = "example-app-frontend-bucket"
artifact_bucket_name       = "example-app-artifacts-bucket"
frontend_noncurrent_version_retention_days = 30
artifact_noncurrent_version_retention_days = 30
root_domain                = "example.com"
frontend_subdomain         = "app"
api_subdomain              = "api.app"
create_frontend_dns_record = true
create_api_dns_record      = true
frontend_certificate_arn   = "arn:aws:acm:us-east-1:123456789012:certificate/example-certificate-id"
certbot_enabled            = false
certbot_staging            = false

# Google OAuth Terraform inputs publish backend runtime values through SSM.
# Phase 5 frontend deploy runtime-config generation still reads GOOGLE_OAUTH_ENABLED
# and GOOGLE_CLIENT_ID from the deploy environment or shared deploy config. Keep
# those deploy values aligned with google_client_id until a later phase wires a
# single source of truth through Terraform outputs.

# google_client_id     = "your-google-client-id"
# google_client_secret = "your-google-client-secret"
# certbot_email        = "ops@example.com"
# key_name = "your-keypair"
# ingress_cidr_blocks = ["0.0.0.0/0"]
